rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Yardımcı fonksiyonlar
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Ürünler - herkes okuyabilir, sadece admin yazabilir
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Siparişler - kendi siparişini okuyabilir, misafir siparişleri herkes (ID ile) okuyabilir, admin hepsini
    match /orders/{orderId} {
      // get: tek belge okuma (doc ID ile)
      allow get: if isAdmin()
                 || (isAuthenticated() && resource.data.customerId == request.auth.uid)
                 || resource.data.isGuest == true;
      // list: sorgu ile okuma - misafir siparisleri icin isGuest filtresi zorunlu
      allow list: if isAdmin()
                  || (isAuthenticated() && resource.data.customerId == request.auth.uid)
                  || (resource.data.isGuest == true);
      // Misafir checkout için - zorunlu alanlar kontrolü
      allow create: if request.resource.data.keys().hasAll(['customer', 'items', 'payment', 'status'])
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 50;
      allow update, delete: if isAdmin();
    }

    // Müşteriler - sadece kendi profilini okuyabilir, admin hepsini
    match /customers/{customerId} {
      allow read: if isAdmin() || isOwner(customerId);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isOwner(customerId);
      allow delete: if isAdmin();
    }

    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Site ayarları - herkes okuyabilir, sadece admin yazabilir
    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Uygulama ayarları - herkes okuyabilir, sadece admin yazabilir
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site içerik (CMS) - herkes okuyabilir, sadece admin yazabilir
    match /site_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Kutu konfigürasyonu - herkes okuyabilir, sadece admin yazabilir
    match /box_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Email kuyruğu - sadece admin veya backend (Cloud Functions admin SDK ile bypass eder)
    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin();
    }

    // Visitor sessions - oluşturma ve güncelleme için boyut sınırı
    match /sessions/{sessionId} {
      allow create: if request.resource.data.keys().size() <= 20;
      allow update: if request.resource.data.keys().size() <= 20;
      allow read: if true;
      allow delete: if isAdmin();
    }

    // Visitors - oluşturma ve güncelleme için boyut sınırı
    match /visitors/{visitorId} {
      allow create: if request.resource.data.keys().size() <= 20;
      allow update: if request.resource.data.keys().size() <= 20;
      allow read, delete: if isAdmin();
    }

    // Konuşma logları - boyut sınırı ile
    match /conversation_logs/{logId} {
      allow create: if request.resource.data.keys().size() <= 15;
      allow read, update, delete: if isAdmin();
    }

    // Yorum sistemi
    match /reviews/{reviewId} {
      // Herkes okuyabilir (ana sayfa carousel + yorum yazma sayfası)
      allow read: if true;
      // Authenticated kullanıcılar (admin) oluşturabilir ve yönetebilir
      allow create, delete: if request.auth != null;
      // Admin güncelleyebilir VEYA token sahibi (misafir) yorum yazabilir
      allow update: if isAdmin()
                    || (request.resource.data.token == resource.data.token);
    }

    // Kuponlar - herkes okuyabilir, sadece admin yazabilir
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter abonelikleri - email alanı zorunlu, boyut sınırlı
    match /newsletter/{subscriberId} {
      allow create: if request.resource.data.keys().hasAll(['email'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 5
                    && request.resource.data.email.size() < 100
                    && request.resource.data.keys().size() <= 10;
      allow read, update, delete: if isAdmin();
    }

    // Bonbon koleksiyonları - herkes okuyabilir, sadece admin yazabilir
    match /bonbon_collections/{collectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bonbons/{bonbonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sadakat programı ayarları - herkes okuyabilir, sadece admin yazabilir
    match /loyalty_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ürün rozetleri - herkes okuyabilir, sadece admin yazabilir
    match /product_badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Kampanyalar
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Referans kodları
    match /referral_codes/{codeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Varsayılan kural - diğer tüm koleksiyonlar sadece admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
